# Shared runtime
DEVICE=cpu           # cuda | cpu
LOG_LEVEL=INFO
CUDA_VISIBLE_DEVICES=0

# Redis / async backend
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# API / worker process settings
API_WORKERS=2
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_LOGLEVEL=info

# Primary detection model
MODEL_CHECKPOINT=checkpoints/hybrid_best.ckpt   # .ckpt file or MONAI bundle directory

# False-positive reduction model
FP_CHECKPOINT=checkpoints/fp_reduction_best.ckpt
FP_THRESHOLD=0.5     # probability threshold; set per config after tuning

# Project-native candidate generation knobs
CANDIDATE_THRESHOLD=0.5
MIN_CANDIDATE_VOXELS=10
PRIMARY_PATCH_SIZE=256
